<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="400.0"
            stylesheets="/css/style.css"
            styleClass="login-root"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.expensemanager.controller.ForgotPasswordController">
   <children>
      <VBox alignment="CENTER" layoutX="50.0" layoutY="50.0"
            prefHeight="400.0" prefWidth="300.0" spacing="15.0"
            styleClass="card"
            AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="50.0"
            AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="50.0">
         <children>
            <Label styleClass="page-heading"
                   style="-fx-font-size: 20; -fx-font-weight: bold;"
                   text="Reset Password"/>

            <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-field"/>
            <PasswordField fx:id="newPasswordField" promptText="New Password" styleClass="password-field"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm New Password" styleClass="password-field"/>

            <Label fx:id="statusLabel" textFill="RED" wrapText="true"/>

            <Button mnemonicParsing="false" onAction="#handleSubmit"
                    prefWidth="200.0" styleClass="btn-primary" text="Reset Password"/>
            <Button mnemonicParsing="false" onAction="#handleCancel"
                    prefWidth="200.0" styleClass="btn-secondary" text="Cancel"/>
         </children>
      </VBox>
   </children>
</AnchorPane>
