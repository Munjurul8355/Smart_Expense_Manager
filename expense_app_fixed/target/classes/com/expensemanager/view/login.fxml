<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.expensemanager.controller.LoginController"
      styleClass="login-root">

    <VBox spacing="20" styleClass="card" maxWidth="400" alignment="CENTER">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Icon + Title -->
        <VBox alignment="CENTER" spacing="10">
            <VBox alignment="CENTER"
                  styleClass="icon-badge-blue"
                  style="-fx-padding: 15; -fx-background-radius: 50;">
                <FontIcon iconLiteral="fas-wallet" iconSize="32" iconColor="#4F46E5"/>
            </VBox>
            <Label text=" Smart Expense " styleClass="page-heading"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Sign in to your account" styleClass="text-muted"/>
        </VBox>

        <!-- Fields -->
        <VBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 20 0 0 0;">

            <!-- Email -->
            <VBox spacing="5">
                <Label text="Email Address" styleClass="field-label"
                       style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField" promptText="name@example.com"/>
            </VBox>

            <!-- Password with Eye Toggle -->
            <VBox spacing="5">
                <HBox>
                    <Label text="Password" styleClass="field-label"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Button text="Forgot?" onAction="#goToForgotPassword"
                            style="-fx-background-color: transparent; -fx-text-fill: #6366F1;
                                   -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 0;
                                   -fx-focus-color: transparent; -fx-faint-focus-color: transparent;
                                   -fx-border-color: transparent;"/>
                </HBox>
                <StackPane>
                    <PasswordField fx:id="passwordField" promptText="Enter your password"/>
                    <TextField    fx:id="passwordVisible" promptText="Enter your password"
                                  visible="false" managed="false"/>
                    <Button fx:id="eyeToggleBtn" onAction="#togglePasswordVisibility"
                            style="-fx-background-color: transparent; -fx-cursor: hand;
                                   -fx-padding: 0 12 0 0;
                                   -fx-focus-color: transparent; -fx-faint-focus-color: transparent;
                                   -fx-border-color: transparent; -fx-background-insets: 0;"
                            StackPane.alignment="CENTER_RIGHT">
                        <graphic>
                            <FontIcon fx:id="eyeIcon" iconLiteral="fas-eye-slash"
                                      iconSize="16" iconColor="#94A3B8"/>
                        </graphic>
                    </Button>
                </StackPane>
            </VBox>
        </VBox>

        <Label fx:id="errorLabel" textFill="RED" wrapText="true"/>

        <Button defaultButton="true" maxWidth="Infinity"
                onAction="#handleLogin" styleClass="btn-primary" text="Sign In">
            <font><Font size="14.0"/></font>
        </Button>

        <HBox alignment="CENTER" spacing="5" style="-fx-padding: 10 0 0 0;">
            <Label text="Don't have an account?" styleClass="text-muted"/>
            <Button onAction="#goToRegister" text="Create account"
                    style="-fx-background-color: transparent; -fx-text-fill: #6366F1;
                           -fx-cursor: hand; -fx-font-weight: bold;
                           -fx-focus-color: transparent; -fx-faint-focus-color: transparent;
                           -fx-border-color: transparent;"/>
        </HBox>
    </VBox>
</VBox>
