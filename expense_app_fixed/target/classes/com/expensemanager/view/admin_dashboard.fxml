<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="/css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.expensemanager.controller.AdminDashboardController">
   <children>
      <VBox layoutX="50.0" layoutY="50.0" prefHeight="500.0" prefWidth="700.0" spacing="20.0" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="50.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: -fx-text-primary;" text="Admin Dashboard" />
                  <Label fx:id="statusLabel" textFill="#e11d48" />
               </children>
            </HBox>
            <TableView fx:id="userTable" prefHeight="400.0" prefWidth="700.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="idColumn" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="nameColumn" prefWidth="150.0" text="Name" />
                <TableColumn fx:id="emailColumn" prefWidth="250.0" text="Email" />
                <TableColumn fx:id="dateColumn" prefWidth="200.0" text="Created At" />
              </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleDeleteUser" styleClass="btn-secondary" style="-fx-background-color: #ef4444; -fx-text-fill: white;" text="Delete User" />
                  <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="btn-primary" text="Logout" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
