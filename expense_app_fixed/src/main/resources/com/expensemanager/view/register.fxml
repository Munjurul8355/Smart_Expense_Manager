<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.expensemanager.controller.RegisterController"
      styleClass="register-root">

    <VBox spacing="20" styleClass="card" maxWidth="450" alignment="CENTER">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <VBox alignment="CENTER" spacing="5">
            <Label text="Create your account" styleClass="page-heading"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Start managing your finance today" styleClass="text-muted"/>
        </VBox>

        <VBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
            <VBox spacing="5">
                <Label text="Full Name" styleClass="field-label"
                       style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="nameField" promptText="Your full name"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Email Address" styleClass="field-label"
                       style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField" promptText="name@example.com"/>
            </VBox>

            <HBox spacing="10">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Password" styleClass="field-label"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <PasswordField fx:id="passwordField" promptText="••••••••"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Confirm" styleClass="field-label"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="••••••••"/>
                </VBox>
            </HBox>
        </VBox>

        <Label fx:id="errorLabel" textFill="RED" wrapText="true"/>

        <Button defaultButton="true" maxWidth="Infinity"
                onAction="#handleRegister" styleClass="btn-primary" text="Sign Up">
            <font><Font size="14.0"/></font>
        </Button>

        <HBox alignment="CENTER" spacing="5" style="-fx-padding: 10 0 0 0;">
            <Label text="Already have an account?" styleClass="text-muted"/>
            <Button onAction="#goToLogin" styleClass="btn-text" text="Sign In"/>
        </HBox>
    </VBox>
</VBox>
