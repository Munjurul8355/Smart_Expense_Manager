<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.expensemanager.controller.SummaryController"
            stylesheets="@style.css">
    
    <!-- Sidebar -->
    <left>
        <fx:include source="sidebar.fxml"/>
    </left>
    
    <!-- Main Content -->
    <center>
        <VBox spacing="20" styleClass="main-content">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="Expense Summary" styleClass="page-title"/>
            </HBox>
            
            <!-- Filters -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Period:" styleClass="filter-label"/>
                <ComboBox fx:id="periodComboBox" prefWidth="150"/>
                
                <Label text="Year:" styleClass="filter-label"/>
                <ComboBox fx:id="yearComboBox" prefWidth="100"/>
                
                <Label text="Month:" styleClass="filter-label" 
                       fx:id="monthLabel" visible="true" managed="true"/>
                <ComboBox fx:id="monthComboBox" prefWidth="150" 
                          visible="true" managed="true"/>
                
                <Button text="Generate" onAction="#handleGenerate" 
                        styleClass="btn-primary"/>
            </HBox>
            
            <Separator/>
            
            <!-- Summary Cards -->
            <HBox spacing="20" alignment="CENTER">
                <!-- Income Card -->
                <VBox styleClass="summary-card" spacing="10" 
                      alignment="CENTER" prefWidth="250">
                    <Label text="Total Income" styleClass="card-title"/>
                    <Label fx:id="totalIncomeLabel" text="৳0.00" 
                           styleClass="card-amount income-color"/>
                </VBox>
                
                <!-- Expense Card -->
                <VBox styleClass="summary-card" spacing="10" 
                      alignment="CENTER" prefWidth="250">
                    <Label text="Total Expense" styleClass="card-title"/>
                    <Label fx:id="totalExpenseLabel" text="৳0.00" 
                           styleClass="card-amount expense-color"/>
                </VBox>
                
                <!-- Balance Card -->
                <VBox styleClass="summary-card" spacing="10" 
                      alignment="CENTER" prefWidth="250">
                    <Label text="Balance" styleClass="card-title"/>
                    <Label fx:id="balanceLabel" text="৳0.00" 
                           styleClass="card-amount balance-color"/>
                </VBox>
            </HBox>
            
            <!-- Charts and Details -->
            <HBox spacing="20" VBox.vgrow="ALWAYS">
                <!-- Category Breakdown Table -->
                <VBox spacing="10" prefWidth="450" minWidth="420" maxWidth="480">
                    <Label text="Category Breakdown" styleClass="section-title"/>
                    <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS" minHeight="300">
                        <columns>
                            <TableColumn text="Category"
                                       fx:id="categoryColumn" prefWidth="200" minWidth="180"/>
                            <TableColumn text="Amount"
                                       fx:id="amountColumn" prefWidth="110" minWidth="90"/>
                            <TableColumn text="Percentage"
                                       fx:id="percentageColumn" prefWidth="100" minWidth="90"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
                
                <!-- Pie Chart -->
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Visual Breakdown" styleClass="section-title"/>
                    <PieChart fx:id="categoryPieChart" VBox.vgrow="ALWAYS" minHeight="300"/>
                </VBox>
            </HBox>
            
            <!-- Action Buttons -->
            <HBox spacing="15" alignment="CENTER">
                <Button text="⬅ Back to Dashboard"
                        onAction="#handleBack"
                        styleClass="btn-secondary"/>
                <Button text="📄 Export to PDF"
                        onAction="#handleExportPDF"
                        styleClass="btn-primary"/>
            </HBox>
            
        </VBox>
    </center>
    
</BorderPane>