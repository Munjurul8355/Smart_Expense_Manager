<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.expensemanager.controller.DashboardController"
            stylesheets="/css/style.css"
            styleClass="main-content">

    <!-- Sidebar -->
    <left>
        <fx:include source="sidebar.fxml"/>
    </left>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <VBox spacing="24" style="-fx-padding: 36;">

                <!-- ===== TOP WELCOME HEADER ===== -->
             <HBox alignment="CENTER_LEFT"
                      styleClass="welcome-card"
                      style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 22 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 16, 0, 0, 4);">
                    <VBox spacing="4">
                        <Label fx:id="dashboardWelcomeLabel" text="Welcome back!"
                               styleClass="heading-xl"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <Label fx:id="insightLabel" text="Here's your financial overview."
                               styleClass="text-muted"
                               style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label fx:id="currentDateLabel" text=""
                               styleClass="card-label"
                               style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                        <Button text="Add Transaction" onAction="#handleAddTransaction"
                                styleClass="btn-primary">
                            <graphic><FontIcon iconLiteral="fas-plus" iconColor="white"/></graphic>
                        </Button>
                    </VBox>
                </HBox>

                <!-- Summary Cards -->
                <HBox spacing="20">
                    <!-- Balance -->
                    <VBox styleClass="card" HBox.hgrow="ALWAYS" minWidth="180">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <VBox styleClass="icon-badge-blue" style="-fx-padding: 10; -fx-background-radius: 8;">
                                <FontIcon iconLiteral="fas-balance-scale" iconSize="20" iconColor="#4F46E5"/>
                            </VBox>
                            <Label text="Total Balance" styleClass="card-label"/>
                        </HBox>
                        <Label fx:id="balanceLabel" text="৳0.00"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
                    </VBox>

                    <!-- Income -->
                    <VBox styleClass="card" HBox.hgrow="ALWAYS" minWidth="180">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <VBox styleClass="icon-badge-green" style="-fx-padding: 10; -fx-background-radius: 8;">
                                <FontIcon iconLiteral="fas-arrow-down" iconSize="20" iconColor="#22C55E"/>
                            </VBox>
                            <Label text="Total Income" styleClass="card-label"/>
                        </HBox>
                        <Label fx:id="incomeLabel" text="+৳0.00"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-padding: 10 0 0 0; -fx-text-fill: #22C55E;"/>
                    </VBox>

                    <!-- Expense -->
                    <VBox styleClass="card" HBox.hgrow="ALWAYS" minWidth="180">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <VBox styleClass="icon-badge-red" style="-fx-padding: 10; -fx-background-radius: 8;">
                                <FontIcon iconLiteral="fas-arrow-up" iconSize="20" iconColor="#EF4444"/>
                            </VBox>
                            <Label text="Total Expense" styleClass="card-label"/>
                        </HBox>
                        <Label fx:id="expenseLabel" text="-৳0.00"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-padding: 10 0 0 0; -fx-text-fill: #EF4444;"/>
                    </VBox>
                </HBox>

                <!-- Charts and Table -->
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <!-- Left: Transaction Table -->
                    <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="15">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Transaction History"
                                   styleClass="section-title" style="-fx-font-size: 16px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Sort by:" styleClass="text-muted"/>
                            <ComboBox fx:id="sortComboBox" prefWidth="160"/>
                        </HBox>
                        <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS" minHeight="300">
                            <columns>
                                <TableColumn fx:id="dateColumn"     text="Date"     prefWidth="100"/>
                                <TableColumn fx:id="typeColumn"     text="Type"     prefWidth="80"/>
                                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120"/>
                                <TableColumn fx:id="amountColumn"   text="Amount"   prefWidth="100"/>
                                <TableColumn fx:id="actionColumn"   text="Actions"  prefWidth="140"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>

                    <!-- Right: Charts -->
                    <VBox spacing="20" minWidth="350" maxWidth="400">
                        <VBox styleClass="card">
                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 10 0;">
                                <FontIcon iconLiteral="fas-chart-pie" iconColor="#6366F1" iconSize="18"/>
                                <Label text="Expense Breakdown"
                                       styleClass="chart-section-title"/>
                            </HBox>
                            <PieChart fx:id="expensePieChart" labelsVisible="true"
                                      legendVisible="false" minHeight="250"/>
                        </VBox>

                        <VBox styleClass="card">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontIcon iconLiteral="fas-chart-bar" iconColor="#6366F1" iconSize="18"/>
                                <Label text="Income vs Expense"
                                       styleClass="chart-section-title"/>
                            </HBox>
                            <BarChart fx:id="expenseBarChart" minHeight="200" legendVisible="true">
                                <xAxis><CategoryAxis/></xAxis>
                                <yAxis><NumberAxis/></yAxis>
                            </BarChart>
                        </VBox>
                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
